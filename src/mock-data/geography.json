{
  "routeTypes": [
    {
      "id": "noi-tinh",
      "name": "Nội tỉnh",
      "description": "Lộ trình giao - nhận hàng hóa chỉ trong khu vực của tỉnh thành đó và nằm trong cùng 1 miền gửi hàng.",
      "examples": ["Hà Nội ↔ Hà Nội", "TP.HCM ↔ TP.HCM"],
      "rule": "fromProvinceId === toProvinceId"
    },
    {
      "id": "noi-vung",
      "name": "Nội vùng",
      "description": "Lộ trình giao - nhận hàng hóa giữa 2 tỉnh thành chỉ nằm trong cùng 1 miền gửi hàng.",
      "examples": ["Quảng Ngãi ↔ Đà Nẵng (cùng miền Trung)", "Hà Nội ↔ Tuyên Quang (cùng miền Bắc)"],
      "rule": "fromProvinceId !== toProvinceId && fromRegion === toRegion"
    },
    {
      "id": "lien-vung",
      "name": "Liên vùng",
      "description": "Lộ trình giao - nhận hàng hóa giữa 2 tỉnh thành thuộc 2 miền liền kề, bao gồm: miền Nam với miền Trung; miền Bắc với miền Trung.",
      "examples": ["TP.HCM ↔ Khánh Hòa (Nam ↔ Trung)", "Hà Nội ↔ Quảng Ngãi (Bắc ↔ Trung)"],
      "rule": "adjacentRegionPairs: [['Miền Bắc','Miền Trung'], ['Miền Nam','Miền Trung'], ['Tây Nguyên','Miền Trung'], ['Tây Nguyên','Miền Nam']]"
    },
    {
      "id": "lien-tinh",
      "name": "Liên tỉnh",
      "description": "Lộ trình giao - nhận hàng hóa giữa 2 tỉnh thành thuộc 2 miền: miền Bắc với miền Nam.",
      "examples": ["Hà Nội ↔ Tây Ninh (Bắc ↔ Nam)", "TP.HCM ↔ Lạng Sơn (Nam ↔ Bắc)"],
      "rule": "nonAdjacentRegionPairs: [['Miền Bắc','Miền Nam'], ['Miền Bắc','Tây Nguyên']]"
    }
  ],
